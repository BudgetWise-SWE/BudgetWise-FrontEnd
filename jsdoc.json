{
  "source": {
    "include": ["JS"],
    "includePattern": "\\.js$"
  },
  "opts": {
    "destination": "docs",
    "recurse": true,
    "template": "node_modules/docdash"
  },
  "docdash": {
    "static": true,
    "sort": true,
    "search": true,
    "collapse": true,
    "wrap": true,
    "typedefs": true,
    "private": false
  }
}
